{
  "name": "cdx-chores",
  "version": "0.0.9-canary.2",
  "keywords": [
    "automation",
    "cli",
    "codex",
    "data-conversion",
    "duckdb",
    "ffmpeg",
    "file-processing",
    "file-rename",
    "markdown",
    "video"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-pi2pie/cdx-chores"
  },
  "bin": {
    "cdx-chores": "dist/esm/bin.mjs"
  },
  "files": [
    "dist",
    "LICENSE*",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node scripts/generate-embedded-version.mjs && tsdown",
    "cli": "node dist/esm/bin.mjs",
    "lint": "oxlint --tsconfig tsconfig.json src test scripts",
    "lint:fix": "oxlint --tsconfig tsconfig.json --fix src test scripts",
    "format": "oxfmt src test scripts package.json tsconfig.json .oxlintrc.json .oxfmtrc.json",
    "format:check": "oxfmt --check src test scripts package.json tsconfig.json .oxlintrc.json .oxfmtrc.json"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.0-r.1",
    "@inquirer/prompts": "^8.3.2",
    "@openai/codex-sdk": "^0.116.0",
    "commander": "^14.0.3",
    "fast-xml-parser": "^5.5.7",
    "mammoth": "^1.12.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.5.207",
    "yaml": "^2.8.2",
    "yauzl": "^3.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "picocolors": "^1.1.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
