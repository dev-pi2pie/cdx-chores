{
  "name": "cdx-chores",
  "version": "0.1.2-canary.2",
  "keywords": [
    "automation",
    "cli",
    "codex",
    "data-conversion",
    "duckdb",
    "ffmpeg",
    "file-processing",
    "file-rename",
    "markdown",
    "video"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-pi2pie/cdx-chores"
  },
  "bin": {
    "cdx-chores": "dist/esm/bin.mjs"
  },
  "files": [
    "dist",
    "LICENSE*",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node scripts/generate-embedded-version.mjs && tsdown",
    "cli": "node dist/esm/bin.mjs",
    "lint": "oxlint --tsconfig tsconfig.json src test scripts",
    "lint:fix": "oxlint --tsconfig tsconfig.json --fix src test scripts",
    "format": "oxfmt src test scripts package.json tsconfig.json .oxlintrc.json .oxfmtrc.json",
    "format:check": "oxfmt --check src test scripts package.json tsconfig.json .oxlintrc.json .oxfmtrc.json"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.2-r.1",
    "@inquirer/prompts": "8.4.2",
    "@openai/codex-sdk": "^0.123.0",
    "commander": "^14.0.3",
    "fast-xml-parser": "5.7.1",
    "mammoth": "^1.12.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.6.205",
    "yaml": "^2.8.2",
    "yauzl": "^3.3.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@types/node": "25.6.0",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "picocolors": "^1.1.1",
    "tsdown": "0.21.10",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
